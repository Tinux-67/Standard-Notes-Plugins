{
  "compilerOptions": {
    "incremental": true,
    "outDir": "build/lib",
    "target": "esnext",
    "module": "Node16",
    "lib": [
      "DOM",
      "ESNext"
    ],
    "sourceMap": true,
    "importHelpers": true,
    "declaration": true,
    "rootDir": "src",
    "strict": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": false,
    "noFallthroughCasesInSwitch": true,
    "allowJs": false,
    "jsx": "preserve",
    "moduleResolution": "node16",
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "strictNullChecks": false,
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "paths": {
      "*": ["./src/*"]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "build",
    "scripts"
  ]
}
